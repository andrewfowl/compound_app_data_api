# Database
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/compound_api

# Trigger.dev
# TRIGGER_SECRET_KEY=tr_dev_xxx
# TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxxxxxxxxxxx

# Primary RPC
# CHAINSTACK_RPC_URL=https://ethereum-mainnet.core.chainstack.com/YOUR_AUTH_TOKEN

# Optional comparison RPC
# ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Historical price fallback
# ALCHEMY_PRICES_API_KEY=YOUR_ALCHEMY_API_KEY

# Compound v2 Comptroller
# COMPOUND_V2_COMPTROLLER_ADDRESS=0x3d9819210A31b4961b30EF54bE2aeD79B9c9Cd3B

# Optional local test defaults
# TEST_WALLET_ADDRESS=0xd043c56861F3e80b2C5580d7044a6771F802565D
# TEST_MONTH=2021-05

# Optional uploaded pricing fallback file used by worker if desired
# REPORT_PRICES_FILE=./data/prices.sample.csv

# Logging and pagination
# CHAINSTACK_LOG_PAGE_SIZE=200
# REPORT_RPC_CONCURRENCY=8
# REPORT_PRICE_CONCURRENCY=3

# Optional static market files
# v2 file is optional because the app can discover v2 markets onchain if the file is absent
# COMPOUND_V2_MARKETS_FILE=./data/compound-v2-markets.ethereum.json
# v3 file is recommended and bundled in this app
# COMPOUND_V3_MARKETS_FILE=./data/compound-v3-markets.ethereum.json
